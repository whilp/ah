#!/usr/bin/env cosmic
local fs = require("cosmic.fs")
local json = require("cosmic.json")
local db = require("ah.db")
local conversations = require("ah.conversations")
local cenv = require("cosmic.env")

local TEST_TMPDIR = cenv.get("TEST_TMPDIR") or "/tmp"

local function open_with_conv(name: string): db.DB, string
  local d = db.open(fs.join(TEST_TMPDIR, name))
  local conv = conversations.create_conversation(d)
  return d, conv.id
end

local function test_messages()
  local d, cid = open_with_conv("test_msg.db")
  local msg1 = db.create_message(d, "user", nil, nil, cid)
  assert(msg1.id, "message should have id")
  assert(msg1.role == "user", "role mismatch")
  assert(msg1.seq == 0, "root seq 0")
  local msg2 = db.create_message(d, "assistant", msg1.id, nil, cid)
  assert(msg2.seq == 1, "child seq 1")
  assert(msg2.parent_id == msg1.id, "parent_id mismatch")
  local ancestry = db.get_ancestry(d, msg2.id)
  assert(#ancestry == 2, "ancestry len 2")
  assert(ancestry[1].id == msg1.id and ancestry[2].id == msg2.id, "ancestry order")
  local last = db.get_last_message(d)
  assert(last and last.id == msg2.id, "last message")
  db.close(d)
end
test_messages()

local function test_content_blocks()
  local d, cid = open_with_conv("test_cb.db")
  local msg = db.create_message(d, "assistant", nil, nil, cid)
  local b1 = db.add_content_block(d, msg.id, "text", {content = "Hello world"})
  assert(b1.seq == 0 and b1.content == "Hello world", "first block")
  local b2 = db.add_content_block(d, msg.id, "tool_use", {tool_id = "t1", tool_name = "read", tool_input = '{"path":"/tmp"}'})
  assert(b2.seq == 1 and b2.tool_name == "read", "second block")
  local blocks = db.get_content_blocks(d, msg.id)
  assert(#blocks == 2 and blocks[1].block_type == "text" and blocks[2].block_type == "tool_use", "block types")
  db.update_content_block(d, b2.id, {tool_output = "file contents"})
  blocks = db.get_content_blocks(d, msg.id)
  assert(blocks[2].tool_output == "file contents", "update")
  db.close(d)
end
test_content_blocks()

local function test_forking()
  local d, cid = open_with_conv("test_fork.db")
  local m1 = db.create_message(d, "user", nil, nil, cid)
  local m2 = db.create_message(d, "assistant", m1.id, nil, cid)
  local m3 = db.create_message(d, "user", m2.id, nil, cid)
  local m4 = db.create_message(d, "assistant", m3.id, nil, cid)
  local fork = db.create_message(d, "user", m2.id, nil, cid)
  assert(fork.seq == 2 and fork.parent_id == m2.id, "fork")
  local fa = db.get_ancestry(d, fork.id)
  assert(#fa == 3 and fa[1].id == m1.id and fa[3].id == fork.id, "fork ancestry")
  assert(#db.get_ancestry(d, m4.id) == 4, "original ancestry")
  db.close(d)
end
test_forking()

local function test_get_message_count()
  local d0, _ = open_with_conv("count_e2.db")
  assert(db.get_message_count(d0) == 0, "empty 0")
  db.close(d0)
  local d1, c1 = open_with_conv("count_12.db")
  db.create_message(d1, "user", nil, nil, c1)
  assert(db.get_message_count(d1) == 1, "count 1")
  db.close(d1)
end
test_get_message_count()

local function test_get_first_user_prompt()
  local d0, _ = open_with_conv("pr_e2.db")
  assert(db.get_first_user_prompt(d0) == "", "empty prompt")
  db.close(d0)
  local d1, c1 = open_with_conv("pr_u2.db")
  local msg = db.create_message(d1, "user", nil, nil, c1)
  db.add_content_block(d1, msg.id, "text", {content = "Hello world"})
  assert(db.get_first_user_prompt(d1) == "Hello world", "first prompt")
  db.close(d1)
end
test_get_first_user_prompt()

local function test_cleanup_orphans()
  local d, cid = open_with_conv("orph2.db")
  local msg1 = db.create_message(d, "user", nil, nil, cid)
  db.add_content_block(d, msg1.id, "text", {content = "hello"})
  db.create_message(d, "assistant", msg1.id, nil, cid) -- orphan: no blocks
  assert(db.get_message_count(d) == 2, "before cleanup")
  assert(db.cleanup_orphans(d) == 1, "cleaned 1")
  assert(db.get_message_count(d) == 1, "after cleanup")
  db.close(d)
end
test_cleanup_orphans()

local function test_cleanup_preserves_chain()
  local d, cid = open_with_conv("orph_ch2.db")
  local m1 = db.create_message(d, "user", nil, nil, cid)
  db.add_content_block(d, m1.id, "text", {content = "hello"})
  local orphan = db.create_message(d, "assistant", m1.id, nil, cid)
  local m2 = db.create_message(d, "user", orphan.id, nil, cid)
  db.add_content_block(d, m2.id, "text", {content = "world"})
  assert(db.cleanup_orphans(d) == 0, "should not clean orphan with children")
  assert(#db.get_ancestry(d, m2.id) == 3, "ancestry preserved")
  db.close(d)
end
test_cleanup_preserves_chain()

local function test_transactions()
  local d, cid = open_with_conv("tx2.db")
  db.begin_transaction(d)
  local msg = db.create_message(d, "user", nil, nil, cid)
  db.add_content_block(d, msg.id, "text", {content = "hello"})
  db.commit(d)
  assert(#db.get_content_blocks(d, msg.id) == 1, "commit ok")
  db.begin_transaction(d)
  db.create_message(d, "assistant", msg.id, nil, cid)
  db.rollback(d)
  assert(db.get_message_count(d) == 1, "rollback ok")
  db.close(d)
end
test_transactions()

local function test_message_metadata()
  local d, cid = open_with_conv("meta2.db")
  local m1 = db.create_message(d, "user", nil, nil, cid)
  assert(m1.input_tokens == nil and m1.model == nil, "user no metadata")
  local m2 = db.create_message(d, "assistant", m1.id, {
      input_tokens = 100, output_tokens = 50, stop_reason = "end_turn",
      model = "claude-sonnet", api_latency_ms = 1500,
    }, cid)
  assert(m2.input_tokens == 100 and m2.output_tokens == 50, "tokens")
  assert(m2.stop_reason == "end_turn" and m2.model == "claude-sonnet", "model/stop")
  assert(m2.api_latency_ms == 1500, "latency")
  db.close(d)
end
test_message_metadata()

local function test_content_block_duration_and_details()
  local d, cid = open_with_conv("dur_det2.db")
  local msg = db.create_message(d, "user", nil, nil, cid)
  local b1 = db.add_content_block(d, msg.id, "text", {content = "hello"})
  assert(b1.duration_ms == nil and b1.details == nil, "text defaults")
  local details_json = '{"path":"/tmp/test.txt","line_count":42}'
  local b2 = db.add_content_block(d, msg.id, "tool_result", {
      tool_id = "t1", tool_output = "output", duration_ms = 250, details = details_json,
    })
  assert(b2.duration_ms == 250 and b2.details == details_json, "tool_result fields")
  local blocks = db.get_content_blocks(d, msg.id)
  assert(blocks[1].duration_ms == nil and blocks[2].duration_ms == 250, "duration via query")
  assert(blocks[1].details == nil and blocks[2].details == details_json, "details via query")
  db.close(d)
end
test_content_block_duration_and_details()

local function test_events()
  local d, cid = open_with_conv("ev2.db")
  local evt1 = db.log_event(d, "startup", nil, nil, cid)
  assert(evt1.id and evt1.event_type == "startup" and evt1.message_id == nil, "event1")
  local msg = db.create_message(d, "user", nil, nil, cid)
  local evt2 = db.log_event(d, "retry", msg.id, '{"attempt":1}', cid)
  assert(evt2.message_id == msg.id and evt2.details == '{"attempt":1}', "event2")
  assert(#db.get_events(d) == 2, "all events")
  assert(#db.get_events(d, "retry") == 1, "filtered events")
  db.close(d)
end
test_events()

local function test_session_state()
  local d, _ = open_with_conv("st2.db")
  assert(db.get_session_state(d) == "idle", "default idle")
  db.set_session_state(d, "processing")
  assert(db.get_session_state(d) == "processing", "processing")
  db.set_session_state(d, "idle")
  assert(db.get_session_state(d) == "idle", "back to idle")
  db.set_session_state(d, "closed")
  assert(db.get_session_state(d) == "closed", "closed")
  db.close(d)
end
test_session_state()

local function test_session_state_persistence()
  local db_path = fs.join(TEST_TMPDIR, "st_persist2.db")
  local d = db.open(db_path)
  conversations.create_conversation(d)
  db.set_session_state(d, "processing")
  db.close(d)
  d = db.open(db_path)
  assert(db.get_session_state(d) == "processing", "persists across reopen")
  db.close(d)
end
test_session_state_persistence()

local function test_session_token_totals()
  local d0, _ = open_with_conv("tok_e2.db")
  local t0 = db.get_session_token_totals(d0)
  assert(t0.input_tokens == 0 and t0.output_tokens == 0 and t0.cache_read_tokens == 0, "empty")
  db.close(d0)

  local d, cid = open_with_conv("tok_s2.db")
  local m1 = db.create_message(d, "user", nil, nil, cid)
  local m2 = db.create_message(d, "assistant", m1.id, {input_tokens = 100, output_tokens = 50}, cid)
  db.log_event(d, "api_call_end", m2.id, json.encode({input_tokens = 100, output_tokens = 50}), cid)
  local m3 = db.create_message(d, "user", nil, nil, cid)
  local m4 = db.create_message(d, "assistant", m3.id, {input_tokens = 200, output_tokens = 75}, cid)
  db.log_event(d, "api_call_end", m4.id, json.encode({input_tokens = 200, output_tokens = 75}), cid)
  local t = db.get_session_token_totals(d)
  assert(t.input_tokens == 200, "input last: " .. t.input_tokens)
  assert(t.output_tokens == 125, "output sum: " .. t.output_tokens)
  db.close(d)
end
test_session_token_totals()

local function test_session_token_totals_cache_read()
  local d, cid = open_with_conv("tok_c2.db")
  local m1 = db.create_message(d, "user", nil, nil, cid)
  local m2 = db.create_message(d, "assistant", m1.id, {input_tokens = 5000, output_tokens = 100}, cid)
  db.log_event(d, "api_call_end", m2.id, json.encode({input_tokens = 5000, output_tokens = 100, cache_read_input_tokens = 0}), cid)
  local m3 = db.create_message(d, "user", m2.id, nil, cid)
  local m4 = db.create_message(d, "assistant", m3.id, {input_tokens = 10000, output_tokens = 200}, cid)
  db.log_event(d, "api_call_end", m4.id, json.encode({input_tokens = 5100, output_tokens = 200, cache_read_input_tokens = 4900}), cid)
  local t = db.get_session_token_totals(d)
  assert(t.cache_read_tokens == 4900, "cache_read last: " .. t.cache_read_tokens)
  assert(t.input_tokens == 10000, "input: " .. t.input_tokens)
  assert(t.output_tokens == 300, "output sum: " .. t.output_tokens)
  db.close(d)
end
test_session_token_totals_cache_read()

local function test_set_context_nil()
  local d, _ = open_with_conv("ctx_nil.db")
  db.set_context(d, "test_key", "test_value")
  assert(db.get_context(d, "test_key") == "test_value", "set")
  db.set_context(d, "test_key", nil)
  assert(db.get_context(d, "test_key") == nil, "deleted on nil")
  db.close(d)
end
test_set_context_nil()

local function test_delete_message_cascades_events()
  local d, cid = open_with_conv("del_cas.db")
  local msg = db.create_message(d, "user", nil, nil, cid)
  db.add_content_block(d, msg.id, "text", {content = "hello"})
  db.log_event(d, "test_event", msg.id, nil, cid)
  assert(#db.get_events(d, "test_event") == 1, "event before")
  db.delete_message(d, msg.id)
  assert(#db.get_events(d, "test_event") == 0, "event cascaded")
  db.close(d)
end
test_delete_message_cascades_events()

local function test_with_transaction()
  local d, cid = open_with_conv("with_tx.db")
  local msg_id: string = nil
  db.with_transaction(d, function()
      local msg = db.create_message(d, "user", nil, nil, cid)
      db.add_content_block(d, msg.id, "text", {content = "hello"})
      msg_id = msg.id
    end)
  assert(msg_id and db.get_message_count(d) == 1, "successful tx")
  local ok = pcall(function()
      db.with_transaction(d, function()
          db.create_message(d, "user", nil, nil, cid)
          error("deliberate failure")
        end)
    end)
  assert(db.get_message_count(d) == 1, "failed tx rolled back")
  db.close(d)
end
test_with_transaction()

print("all db tests passed")
